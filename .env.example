# 以下变量仅在本地开发 / 打包脚本中生效；生产安装包使用 src/shared/app-release-config.json 内置值。

# 渲染层：覆盖 Platform API 根地址（pnpm dev / build 时注入）
# VITE_PLATFORM_API_URL=http://127.0.0.1:8010

# 主进程：开发时覆盖素材包下载地址
# ARENA_ASSETS_DOWNLOAD_URL=https://example.com/arena-initial-assets.zip

# 打包脚本：素材 zip 写入 manifest 的 downloadUrl 前缀（pnpm pack:assets）
# ARENA_ASSETS_BASE_URL=https://github.com/qq1171910065/manong-arena/releases/download/v0.1.2

# 发布脚本 Classic PAT（repo 权限），切勿提交
# GITHUB_TOKEN=ghp_xxxxxxxx
